@{
    ViewData["Title"] = "Payslips";
}

<h1 class="h3">Payslips</h1>
<p class="text-muted">Select a payroll run and employee to view a printable payslip (MVP).</p>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-controller="Payslips" asp-action="ViewPayslip" method="get" class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Employee</label>
                <select class="form-select" name="employeeId" asp-items="ViewBag.EmployeeId"></select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Payroll run ID</label>
                <input class="form-control" name="runId" type="number" min="1" placeholder="e.g. 1" />
                <div class="form-text">Find run ID in Payroll → View.</div>
            </div>
            <div class="col-12">
                <button class="btn btn-primary" type="submit">View payslip</button>
            </div>
        </form>
    </div>
</div>

