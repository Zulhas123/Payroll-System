@model List<PayrollSystem.Domain.Entities.PayrollRun>

@{
    ViewData["Title"] = "Payroll Runs";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Payroll runs</h1>
    <a class="btn btn-primary" asp-action="Create">New run</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-striped mb-0 align-middle">
            <thead>
            <tr>
                <th>Created</th>
                <th>Period</th>
                <th class="text-end">Employees</th>
                <th class="text-end" style="width: 150px;">Actions</th>
            </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="4" class="text-muted">No payroll runs yet.</td></tr>
            }
            else
            {
                foreach (var r in Model)
                {
                    <tr>
                        <td>@r.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@r.PayPeriod?.StartDate.ToString("yyyy-MM-dd") - @r.PayPeriod?.EndDate.ToString("yyyy-MM-dd")</td>
                        <td class="text-end">@r.Lines.Count</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@r.Id">View</a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
